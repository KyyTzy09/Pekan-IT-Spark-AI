# Database
DATABASE_URL="postgresql://user:password@localhost:5432/spark_ai?schema=public"
# direct connection to the database (bypassing connection pooler like PgBouncer/Neon pooler for migrations)
DIRECT_URL="postgresql://user:password@localhost:5432/spark_ai?schema=public"

# AI API Keys (pilih minimal satu)
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://api.openai.com/v1"
GROQ_API_KEY="gsk_..."
GEMINI_API_KEY="AIza..."

# Heavy model for chat (Socratic tutor, challenges, curriculum, evaluation)
# Override the default chat model with a more capable one for heavy reasoning.
# Falls back to OPENAI_* if not set.
HEAVY_MODEL_BASE_URL=
HEAVY_MODEL_API_KEY=
HEAVY_MODEL_NAME=deepseek-3.2

# Auth
# Generate pakai: openssl rand -base64 32
AUTH_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Google OAuth
# Kosongkan kalau belum setup. Tombol "Lanjut dengan Google" bakal disable otomatis.
# Cara setup: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudinary (next-cloudinary)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME: required untuk client-side CldImage components
# CLOUDINARY_API_KEY + CLOUDINARY_API_SECRET: server-side only (signed uploads, admin)
# Cara setup: https://console.cloudinary.com/
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
