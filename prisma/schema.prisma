generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  PARENT
  ADMIN
}

enum EducationLevel {
  SMA
  SMK
}

enum SubjectSlug {
  MATEMATIKA
  BAHASA_INDONESIA
  BAHASA_INGGRIS
  IPA
  SEJARAH
  GEOGRAFI
  EKONOMI
  SOSIOLOGI
  PPKN
  SENI_BUDAYA
  PJOK
  PRAKARYA
  BAHASA_DAERAH
  CODING
  CUSTOM
}

enum ConceptStatus {
  NOT_STARTED
  LEARNING
  MASTERED
  STRUGGLING
}

enum SubjectSource {
  OFFICIAL
  AI_GENERATED
  USER_CREATED
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  ESSAY
  TRUE_FALSE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  ADVANCED
}

enum BloomTaxonomy {
  REMEMBER
  UNDERSTAND
  APPLY
  ANALYZE
  EVALUATE
  CREATE
}

enum LearningStyle {
  VISUAL
  TEXTUAL
  EXAMPLE_HEAVY
  SOCRATIC
}

enum ResponseDepth {
  RINGKAS
  MENENGAH
  LENGKAP
}

enum XpSource {
  ANSWER_CORRECT
  CHAT_SESSION
  STREAK
  CONCEPT_MASTERED
  DAILY_QUEST
  WEEKLY_CHALLENGE
  BADGE_UNLOCK
}

enum LinkStatus {
  PENDING
  ACCEPTED
}

enum DocumentMimeType {
  PDF
  DOCX
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(STUDENT)
  isOnboarded   Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  studentProfile      StudentProfile?
  parentProfile       ParentProfile?
  parentStudentLinks  ParentStudentLink[]       @relation("ParentLinks")
  childLinks          ParentStudentLink[]       @relation("ChildLinks")
  questionAttempts    QuestionAttempt[]
  quizAttempts        QuizAttempt[]
  chatSessions        ChatSession[]
  userBadges          UserBadge[]
  userAchievements    UserAchievement[]
  xpTransactions      XpTransaction[]
  streak              Streak?
  dailyQuests         DailyQuest[]
  weeklyChallenges    WeeklyChallenge[]
  studyBuddy          StudyBuddy?
  avatarCustomization AvatarCustomization?
  documents           Document[]
  documentAuditLogs   DocumentAuditLog[]
  knowledgeProfiles   StudentKnowledgeProfile[]
  customSubjects      Subject[]                 @relation("CustomSubjects")
  challenges          Challenge[]
  materials           Material[]
  materialReads       MaterialRead[]
  reflections         Reflection[]
  challengeProgress   UserChallengeProgress[]
  adminActions        AdminAuditLog[]           @relation("AdminActor")
  aiQuota             DailyAiQuota?

  @@map("users")
}

model StudentProfile {
  id                        String          @id @default(cuid())
  userId                    String          @unique
  user                      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  educationLevel            EducationLevel?
  grade                     Int?
  school                    String?
  learningStyle             LearningStyle?
  responseDepth             ResponseDepth   @default(MENENGAH)
  focusedSubjects           String[]        @default([])
  challengeSubjectIds       String[]        @default([])
  weeklyChallengeSubjectIds String[]        @default([])
  reminderEnabled           Boolean         @default(false)
  reminderTime              String?
  totalXp                   Int             @default(0)
  level                     Int             @default(1)

  @@map("student_profiles")
}

model ParentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("parent_profiles")
}

model ParentStudentLink {
  id         String     @id @default(cuid())
  parentId   String?
  parent     User?      @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  studentId  String
  student    User       @relation("ChildLinks", fields: [studentId], references: [id], onDelete: Cascade)
  inviteCode String
  status     LinkStatus @default(PENDING)
  createdAt  DateTime   @default(now())
  expiresAt  DateTime

  @@unique([inviteCode])
  @@map("parent_student_links")
}

model Subject {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String?
  icon        String?
  color       String?
  order       Int           @default(0)
  isCustom    Boolean       @default(false)
  isActive    Boolean       @default(true)
  source      SubjectSource @default(OFFICIAL)
  createdById String?
  createdBy   User?         @relation("CustomSubjects", fields: [createdById], references: [id], onDelete: SetNull)
  isVerified  Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  topics       Topic[]
  chatSessions ChatSession[]
  challenges   Challenge[]
  materials    Material[]

  @@index([isCustom])
  @@index([source])
  @@index([createdById])
  @@index([isVerified])
  @@map("subjects")
}

model Topic {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  slug        String
  order       Int      @default(0)
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  concepts     Concept[]
  chatSessions ChatSession[]
  materials    Material[]

  @@unique([subjectId, slug])
  @@map("topics")
}

model Concept {
  id          String   @id @default(cuid())
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  name        String
  description String?
  slug        String
  order       Int      @default(0)
  contentMd   String?  @db.Text
  isCustom    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prerequisites     ConceptPrerequisite[]     @relation("ConceptPrerequisites")
  dependents        ConceptPrerequisite[]     @relation("ConceptDependents")
  questions         Question[]
  knowledgeProfiles StudentKnowledgeProfile[]
  embeddings        ConceptEmbedding[]
  materials         Material[]

  @@unique([topicId, slug])
  @@map("concepts")
}

model ConceptPrerequisite {
  prerequisiteId  String
  conceptId       String
  prerequisite    Concept @relation("ConceptPrerequisites", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  dependent       Concept @relation("ConceptDependents", fields: [conceptId], references: [id], onDelete: Cascade)
  minMasteryScore Float?  @default(0.7)

  @@id([prerequisiteId, conceptId])
  @@map("concept_prerequisites")
}

model Question {
  id                   String        @id @default(cuid())
  conceptId            String
  concept              Concept       @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  type                 QuestionType
  difficulty           Difficulty    @default(MEDIUM)
  bloomTaxonomy        BloomTaxonomy @default(UNDERSTAND)
  questionText         String        @db.Text
  options              Json?         @db.JsonB
  correctAnswer        String        @db.Text
  explanation          String?       @db.Text
  hint                 String?       @db.Text
  commonMisconceptions String?       @db.Text
  tags                 String[]      @default([])
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  attempts       QuestionAttempt[]
  quizQuestions  QuizQuestion[]
  challengeItems ChallengeItem[]

  @@index([conceptId])
  @@index([difficulty, bloomTaxonomy])
  @@index([isActive])
  @@map("questions")
}

model QuestionAttempt {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer     String   @db.Text
  isCorrect  Boolean
  timeSpent  Int?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([questionId])
  @@index([userId, questionId])
  @@map("question_attempts")
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  timeLimit   Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id         String   @id @default(cuid())
  quizId     String
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int      @default(0)

  @@unique([quizId, questionId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Float?
  maxScore    Float?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([quizId])
  @@index([userId, quizId])
  @@map("quiz_attempts")
}

model QuizSession {
  id           String   @id
  userId       String
  topicId      String
  questionIds  Json
  startedAt    DateTime
  timeLimitSec Int
  status       String   @default("ACTIVE")

  @@index([userId])
  @@map("quiz_sessions")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("Chat Baru")
  topicId   String?
  topic     Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ChatMessage[]
  documents Document[]

  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String      @db.Text
  metadata  Json?       @db.JsonB
  createdAt DateTime    @default(now())

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  imageUrl    String?
  category    String?
  criteria    Json?    @db.JsonB
  xpReward    Int      @default(0)
  createdAt   DateTime @default(now())

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  imageUrl    String?
  category    String?
  criteria    Json?    @db.JsonB
  xpReward    Int      @default(0)
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime    @default(now())

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model XpTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  source    XpSource
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, source])
  @@map("xp_transactions")
}

model Level {
  level Int    @id
  name  String
  minXp Int
  maxXp Int

  @@map("levels")
}

model Streak {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  lastActivityAt    DateTime?
  freezeAvailable   Int       @default(1)
  lastFreezeResetAt DateTime?
  updatedAt         DateTime  @updatedAt

  @@map("streaks")
}

model DailyQuest {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @default(now())
  quests     Json     @db.JsonB
  completed  Boolean  @default(false)
  xpRewarded Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@map("daily_quests")
}

model WeeklyChallenge {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart   DateTime
  title       String
  description String?
  goal        Int
  progress    Int        @default(0)
  completed   Boolean    @default(false)
  xpRewarded  Boolean    @default(false)
  badgeId     String?
  challengeId String?
  challenge   Challenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())

  @@unique([userId, weekStart])
  @@index([challengeId])
  @@map("weekly_challenges")
}

model StudyBuddy {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("bunga")
  stage     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("study_buddies")
}

model AvatarCustomization {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  color      String   @default("default")
  accessory  String?
  background String?
  updatedAt  DateTime @updatedAt

  @@map("avatar_customizations")
}

model DailyAiQuota {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date
  questionsCount Int      @default(0)
  materialsCount Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@index([date])
  @@map("daily_ai_quotas")
}

model Document {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSessionId String?
  chatSession   ChatSession?        @relation(fields: [chatSessionId], references: [id], onDelete: SetNull)
  originalName  String
  mimeType      DocumentMimeType
  size          Int
  pageCount     Int?
  content       String              @db.Text
  summary       String?             @db.Text
  createdAt     DateTime            @default(now())
  embeddings    DocumentEmbedding[]
  auditLogs     DocumentAuditLog[]
  quizzes       DocumentQuiz[]
  materials     Material[]

  @@index([userId])
  @@index([chatSessionId])
  @@map("documents")
}

model ConceptEmbedding {
  id        String   @id @default(cuid())
  conceptId String   @unique
  concept   Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  embedding String   @db.Text
  createdAt DateTime @default(now())

  @@map("concept_embeddings")
}

model DocumentEmbedding {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex   Int
  chunkContent String   @db.Text
  embedding    String   @db.Text
  createdAt    DateTime @default(now())

  @@unique([documentId, chunkIndex])
  @@map("document_embeddings")
}

model DocumentAuditLog {
  id         String              @id @default(cuid())
  documentId String
  document   Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     DocumentAuditAction
  metadata   Json?               @db.JsonB
  createdAt  DateTime            @default(now())

  @@index([documentId])
  @@index([userId])
  @@index([action])
  @@map("document_audit_logs")
}

enum DocumentAuditAction {
  UPLOAD
  PROCESS
  SUMMARY_GENERATED
  QUIZ_GENERATED
  SHARE_TO_CHAT
  CHAT_REFERENCED
  RAG_QUERY
  DELETE
  REJECTED
}

model StudentKnowledgeProfile {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conceptId     String
  concept       Concept       @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  masteryScore  Float         @default(0)
  status        ConceptStatus @default(NOT_STARTED)
  attemptCount  Int           @default(0)
  lastAttemptAt DateTime?
  updatedAt     DateTime      @updatedAt

  @@unique([userId, conceptId])
  @@index([userId])
  @@index([status])
  @@map("student_knowledge_profiles")
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  SKIPPED
  EXPIRED
}

enum ChallengeType {
  DAILY
  WEEKLY
}

enum ChallengeItemKind {
  QUESTION
  MATERIAL
  REFLECTION
}

enum ChallengeItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ChallengeSource {
  AUTO_DAILY
  AUTO_WEEKLY
  ON_DEMAND
}

enum MaterialSource {
  CHALLENGE
  ON_DEMAND
  ADAPTIVE
}

enum ReflectionSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum ReflectionDepth {
  SURFACE
  MODERATE
  DEEP
}

model Challenge {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId       String?
  subject         Subject?          @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  title           String
  description     String            @db.Text
  type            ChallengeType     @default(DAILY)
  status          ChallengeStatus   @default(ACTIVE)
  source          ChallengeSource   @default(AUTO_DAILY)
  scheduledFor    DateTime          @db.Date
  mixConfig       Json              @db.JsonB
  generatedAt     DateTime          @default(now())
  completedAt     DateTime?
  items           ChallengeItem[]
  reflections     Reflection[]
  weeklyChallenge WeeklyChallenge[]

  @@index([userId, scheduledFor])
  @@index([userId, status])
  @@index([userId, subjectId])
  @@index([userId, type])
  @@map("challenges")
}

model ChallengeItem {
  id          String              @id @default(cuid())
  challengeId String
  challenge   Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  order       Int
  kind        ChallengeItemKind
  questionId  String?
  question    Question?           @relation(fields: [questionId], references: [id], onDelete: SetNull)
  materialId  String?
  material    Material?           @relation(fields: [materialId], references: [id], onDelete: SetNull)
  prompt      String?             @db.Text
  status      ChallengeItemStatus @default(PENDING)
  points      Int                 @default(0)
  completedAt DateTime?
  answer      String?             @db.Text
  isCorrect   Boolean?

  @@index([challengeId, order])
  @@map("challenge_items")
}

model Material {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId        String?
  subject          Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  topicId          String?
  topic            Topic?          @relation(fields: [topicId], references: [id], onDelete: SetNull)
  conceptId        String?
  concept          Concept?        @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  documentId       String?
  document         Document?       @relation(fields: [documentId], references: [id], onDelete: SetNull)
  title            String
  content          String          @db.Text
  keyPoints        Json?           @db.JsonB
  difficulty       Difficulty      @default(MEDIUM)
  estimatedMinutes Int             @default(5)
  source           MaterialSource  @default(CHALLENGE)
  createdAt        DateTime        @default(now())
  challengeItems   ChallengeItem[]
  reads            MaterialRead[]

  @@index([userId, subjectId])
  @@index([userId, createdAt])
  @@index([userId, source])
  @@index([documentId])
  @@map("materials")
}

model MaterialRead {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  materialId  String
  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  readAt      DateTime @default(now())
  readSeconds Int      @default(0)
  completed   Boolean  @default(false)

  @@unique([userId, materialId])
  @@index([userId, readAt])
  @@map("material_reads")
}

model Reflection {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  prompt      String              @db.Text
  response    String              @db.Text
  sentiment   ReflectionSentiment @default(NEUTRAL)
  depth       ReflectionDepth     @default(SURFACE)
  suggestions Json?               @db.JsonB
  submittedAt DateTime            @default(now())

  @@index([userId, challengeId])
  @@index([userId, submittedAt])
  @@map("reflections")
}

model UserChallengeProgress {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                 DateTime @db.Date
  totalActive          Int      @default(0)
  totalCompleted       Int      @default(0)
  totalPoints          Int      @default(0)
  pointsByKind         Json     @db.JsonB
  questionsCompleted   Int      @default(0)
  materialsCompleted   Int      @default(0)
  reflectionsSubmitted Int      @default(0)
  updatedAt            DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@map("user_challenge_progress")
}

model DocumentQuiz {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  title      String
  questions  Json     @db.JsonB // Array of quiz questions
  attempts   Json     @default("[]") @db.JsonB // Array of attempts
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([documentId])
  @@map("document_quizzes")
}

enum AdminAction {
  CUSTOM_SUBJECT_APPROVE
  CUSTOM_SUBJECT_REJECT
  USER_BAN
  USER_UNBAN
  USER_SUSPEND
  USER_UNSUSPEND
  CONTENT_DELETE
}

model AdminAuditLog {
  id         String      @id @default(cuid())
  adminId    String
  admin      User        @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)
  action     AdminAction
  targetType String
  targetId   String
  metadata   Json?       @db.JsonB
  note       String?     @db.Text
  createdAt  DateTime    @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@index([action])
  @@map("admin_audit_log")
}

model ParentTipCache {
  id        String   @id @default(cuid())
  studentId String
  forDate   String
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@unique([studentId, forDate])
  @@index([studentId])
  @@map("parent_tip_cache")
}
